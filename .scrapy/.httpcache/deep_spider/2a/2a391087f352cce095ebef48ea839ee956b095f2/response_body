                            '900': 'fa-temperature-high', // 热
                            '901': 'fa-temperature-low', // 冷
                            '999': 'fa-question' // 未知
                        };
                        
                        return iconMap[iconCode] || 'fa-cloud';
                    }
                    
                    // 获取星期几
                    function getDayOfWeek(dateStr) {
                        const date = new Date(dateStr);
                        const days = ['周日', '周一', '周二', '周三', '周四', '周五', '周六'];
                        return days[date.getDay()];
                    }
                    
                    // 格式化天气数据
                    const current = weatherData.now;
                    const forecast = forecastData.daily.slice(0, 3); // 取未来3天
                    
                    return {
                        current: {
                            temp: current.temp,
                            condition: current.text,
                            humidity: current.humidity,
                            wind: current.windSpeed,
                            icon: mapWeatherIcon(current.icon),
                            location: cityName
                        },
                        forecast: forecast.map(day => ({
                            date: day.fxDate,
                            day: getDayOfWeek(day.fxDate),
                            temp: day.tempMax,
                            tempMin: day.tempMin,
                            icon: mapWeatherIcon(day.iconDay)
                        }))
                    };
                } else {
                    throw new Error("天气数据获取失败");
                }
            } catch (error) {
                console.error("获取天气数据错误:", error);
                // 返回模拟数据作为备份
                return {
