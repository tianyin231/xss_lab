        // 搜索功能
        const searchBar = document.querySelector('.search-bar');
        const searchHistory = document.querySelector('.search-history');
        const historyItems = document.querySelector('.history-items');
        const clearHistoryBtn = document.querySelector('.clear-history');
        
        // 从localStorage加载搜索历史
        function loadSearchHistory() {
            const history = JSON.parse(localStorage.getItem('searchHistory')) || [];
            return history;
        }
        
        // 保存搜索历史到localStorage
        function saveSearchHistory(history) {
            localStorage.setItem('searchHistory', JSON.stringify(history));
        }
        
        // 添加搜索记录
        function addSearchToHistory(searchTerm) {
            let history = loadSearchHistory();
            
            // 移除重复项
            history = history.filter(item => item !== searchTerm);
            
            // 添加到开头
            history.unshift(searchTerm);
            
            // 保留最近的10条记录
            if (history.length > 10) {
                history = history.slice(0, 10);
            }
            
            saveSearchHistory(history);
            renderSearchHistory();
        }
        
        // 渲染搜索历史
        function renderSearchHistory() {
            const history = loadSearchHistory();
            
            // 如果历史为空，隐藏历史面板
            if (history.length === 0) {
                searchHistory.classList.remove('show');
                return;
            }
            
            historyItems.innerHTML = '';
            history.forEach(term => {
                const item = document.createElement('div');
                item.className = 'history-item';
                item.innerHTML = `<i class="fas fa-history"></i>${term}`;
                item.addEventListener('click', () => {
                    performSearch(term);
                });
                historyItems.appendChild(item);
            });
            
            searchHistory.classList.add('show');
        }
        
        // 清空搜索历史
        clearHistoryBtn.addEventListener('click', () => {
            localStorage.removeItem('searchHistory');
            renderSearchHistory();
            searchHistory.classList.remove('show');
        });
        
        // 执行搜索
        function performSearch(searchTerm) {
            searchBar.value = searchTerm;
            
            // 简单的关键词匹配导航
            if (searchTerm.includes('食') || searchTerm.includes('吃') || searchTerm.includes('餐')) {
                window.location.href = '/food';
            } 
            else if (searchTerm.includes('资源') || searchTerm.includes('分享') || searchTerm.includes('学习')) {
                window.location.href = '/resource';
            } 
            else if (searchTerm.includes('活动') || searchTerm.includes('参与') || searchTerm.includes('社团')) {
                window.location.href = '/activity';
            } 
            else if (searchTerm.includes('指南') || searchTerm.includes('导航') || searchTerm.includes('地图')) {
                window.location.href = '/guide';
            } 
            else {
                alert('未找到与 "' + searchTerm + '" 相关的内容，请尝试其他关键词');
            }
            
            // 添加到历史记录
            addSearchToHistory(searchTerm);
            
            // 清空输入框
            searchBar.value = '';
        }
        
        // 搜索栏按键事件
        searchBar.addEventListener('keyup', function(e) {
            if (e.key === 'Enter') {
                const searchTerm = this.value.trim().toLowerCase();
                if (searchTerm) {
                    performSearch(searchTerm);
                }
            }
        });
        
        // 搜索栏获得焦点时显示历史记录
        searchBar.addEventListener('focus', function() {
            renderSearchHistory();
        });
        
        // 初始化历史搜索
        renderSearchHistory();
    </script>
</body>

</html>