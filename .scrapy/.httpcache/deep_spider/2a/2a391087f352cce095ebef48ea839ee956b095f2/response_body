        // 天气API集成 - 使用和风天气API
        async function getWeatherData() {
            // 和风天气API配置
            const apiKey = "8aff6dac568f40fe853d5e606b38d111"; // API密钥
            const geoUrl = "https://geoapi.qweather.com/v2/city/lookup";
            const weatherUrl = "https://devapi.qweather.com/v7/weather/now";
            const forecastUrl = "https://devapi.qweather.com/v7/weather/3d";
            
            try {
                // 首先尝试使用地理定位API获取用户位置
                const position = await new Promise((resolve, reject) => {
                    if (navigator.geolocation) {
                        navigator.geolocation.getCurrentPosition(resolve, reject, {
                            timeout: 10000,
                            enableHighAccuracy: true
                        });
                    } else {
                        reject(new Error("浏览器不支持地理定位"));
                    }
                }).catch(() => {
                    // 如果用户拒绝位置请求或发生错误，使用默认位置（河北廊坊）
                    console.log("地理定位失败，使用默认位置");
                    return null;
                });
                
                let cityId = "101090602"; // 默认河北廊坊
                let cityName = "河北廊坊";
                
                // 如果成功获取到用户位置，则查询对应城市
                if (position) {
                    const {latitude, longitude} = position.coords;
                    const geoResponse = await fetch(`${geoUrl}?location=${longitude},${latitude}&key=${apiKey}`);
                    const geoData = await geoResponse.json();
                    
                    if (geoData.code === "200" && geoData.location && geoData.location.length > 0) {
                        cityId = geoData.location[0].id;
                        cityName = geoData.location[0].adm2 + geoData.location[0].name;
                    }
                }
                
                // 获取实时天气数据
                const weatherResponse = await fetch(`${weatherUrl}?location=${cityId}&key=${apiKey}`);
                const weatherData = await weatherResponse.json();
                
                // 获取天气预报数据
                const forecastResponse = await fetch(`${forecastUrl}?location=${cityId}&key=${apiKey}`);
                const forecastData = await forecastResponse.json();
                
                if (weatherData.code === "200" && forecastData.code === "200") {
                    // 映射天气图标代码到Font Awesome图标
                    function mapWeatherIcon(iconCode) {
                        const iconMap = {
                            '100': 'fa-sun', // 晴
                            '101': 'fa-cloud-sun', // 多云
                            '102': 'fa-cloud-sun', // 少云
                            '103': 'fa-cloud', // 晴间多云
                            '104': 'fa-cloud', // 阴
                            '300': 'fa-cloud-rain', // 阵雨
                            '301': 'fa-cloud-showers-heavy', // 强阵雨
                            '302': 'fa-cloud-rain', // 雷阵雨
                            '303': 'fa-bolt', // 强雷阵雨
                            '304': 'fa-snowflake', // 雷阵雨伴有冰雹
                            '305': 'fa-cloud-rain', // 小雨
                            '306': 'fa-cloud-rain', // 中雨
