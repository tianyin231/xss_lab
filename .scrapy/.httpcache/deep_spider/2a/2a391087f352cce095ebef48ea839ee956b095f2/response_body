        // 轮播图功能
        const images = document.querySelectorAll('.carousel img');
        let current = 0;

        function showNextImage() {
            images[current].classList.remove('active');
            current = (current + 1) % images.length;
            images[current].classList.add('active');
        }

        function startCarousel() {
            images[0].classList.add('active');
            setInterval(showNextImage, 5000); // 把间隔时间改回5000，与原来保持一致
        }

        // 更新日志展开/收起功能
        document.addEventListener('DOMContentLoaded', function() {
            // 启动轮播图
            startCarousel();
            
            const toggleBtn = document.getElementById('toggleUpdateLog');
            const updateLogContent = document.getElementById('updateLogContent');
            const btnText = toggleBtn.querySelector('span');
            
            toggleBtn.addEventListener('click', function() {
                if (updateLogContent.classList.contains('collapsed')) {
                    // 展开内容
                    updateLogContent.classList.remove('collapsed');
                    updateLogContent.classList.add('expanded');
                    btnText.textContent = '收起';
                    toggleBtn.classList.add('expanded');
                } else {
                    // 收起内容
                    updateLogContent.classList.remove('expanded');
                    updateLogContent.classList.add('collapsed');
                    btnText.textContent = '展开';
                    toggleBtn.classList.remove('expanded');
                }
            });
        });

